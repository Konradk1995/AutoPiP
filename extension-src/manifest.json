{
  "manifest_version": 3,
  "name": "Auto PiP",
  "version": "1.1",
  "description": "Automatically enters Picture-in-Picture when you leave the tab.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png"
  }
}
